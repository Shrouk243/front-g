APP_NAME="Healthcare App API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Africa/Cairo

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=replace_with_hostinger_db_name
DB_USERNAME=replace_with_hostinger_db_user
DB_PASSWORD=replace_with_hostinger_db_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com,api.your-domain.com
SANCTUM_TOKEN_EXPIRATION=43200
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,exp://your-expo-domain

PASSWORD_RESET_EXPOSE_CODE=false

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=replace_with_email_username
MAIL_PASSWORD=replace_with_email_password
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"
